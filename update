#!/bin/bash
set -Eeuo pipefail
export TERM=${TERM:-xterm-256color}

APP_NAME=${APP_NAME:-sellvpn}
BOT_DIR=${BOT_DIR:-/root/BotVPN}
REPO_URL=${REPO_URL:-https://github.com/sahal-max/bot.git}
BRANCH=${BRANCH:-main}
BACKUP_ROOT=${BACKUP_ROOT:-/tmp}
BACKUP_DIR="${BACKUP_ROOT%/}/botvpn_update_$(date +%Y%m%d_%H%M%S)"
CONFIG_FILES=(
  ".vars.json"
  "join_channel.json"
  "reseller_terms.json"
  "sc_nexus_menu.json"
  "test_menu.json"
  "topup_manual.json"
  "app.js"
  "modules/create.js"
  "modules/createzivpn.js"
  "modules/trial.js"
  "modules/trialzivpn.js"
  "modules/cloudfront.js"
)

# Pola file/folder sampah (backup manual, hasil patch, db corrupt, dll)
# yang otomatis dibersihkan setiap update supaya tidak perlu hapus manual lagi.
JUNK_NAME_PATTERNS=(
  "*.bak"
  "*.bak_*"
  "*.backup*"
  "*.corrupt*"
  "*.corrupt_*"
  "*.fixed"
  "database.sqlite"
)
JUNK_DIR_PATTERNS=(
  "db_corrupt_backup_*"
)
# Folder yang selalu disisakan minimal 1 (paling baru) untuk jaga-jaga
KEEP_LATEST_DIR_PATTERNS=(
  "db_recovery_*"
)

red='\033[0;31m'
green='\033[0;32m'
yellow='\033[1;33m'
blue='\033[0;34m'
neutral='\033[0m'

log() { echo -e "${blue}==>${neutral} $*"; }
success() { echo -e "${green}✅ $*${neutral}"; }
warn() { echo -e "${yellow}⚠ $*${neutral}"; }
fail() { echo -e "${red}❌ $*${neutral}" >&2; exit 1; }

run() {
  log "$*"
  "$@"
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

backup_file() {
  local src="$1"
  local rel="${src#$BOT_DIR/}"
  local dst="$BACKUP_DIR/$rel"
  mkdir -p "$(dirname "$dst")"
  cp -a "$src" "$dst"
}

restore_backup() {
  if [ ! -d "$BACKUP_DIR" ]; then
    return 0
  fi

  log "Mengembalikan konfigurasi dan database dari $BACKUP_DIR"
  for item in "${CONFIG_FILES[@]}"; do
    if [ -e "$BACKUP_DIR/$item" ]; then
      cp -a "$BACKUP_DIR/$item" "$BOT_DIR/$item"
    fi
  done

  find "$BACKUP_DIR" -maxdepth 1 -type f \( -name '*.db' -o -name '*.db-shm' -o -name '*.db-wal' \) -print0 |
    while IFS= read -r -d '' file; do
      cp -a "$file" "$BOT_DIR/$(basename "$file")"
    done
}

cleanup_junk() {
  if [ ! -d "$BOT_DIR" ]; then
    return 0
  fi

  log "Bersihkan file sampah (backup lama, hasil patch, db corrupt)"
  local removed=0

  # File sampah level atas (bukan di dalam .git/node_modules)
  local name_expr=()
  for pat in "${JUNK_NAME_PATTERNS[@]}"; do
    [ ${#name_expr[@]} -gt 0 ] && name_expr+=(-o)
    name_expr+=(-name "$pat")
  done

  while IFS= read -r -d '' file; do
    rm -f "$file"
    removed=$((removed + 1))
  done < <(find "$BOT_DIR" -maxdepth 2 \
              -path "$BOT_DIR/node_modules" -prune -o \
              -path "$BOT_DIR/.git" -prune -o \
              -type f \( "${name_expr[@]}" \) -print0 2>/dev/null)

  # Folder sampah (mis. db_corrupt_backup_*) - hapus semua
  for pat in "${JUNK_DIR_PATTERNS[@]}"; do
    while IFS= read -r -d '' dir; do
      rm -rf "$dir"
      removed=$((removed + 1))
    done < <(find "$BOT_DIR" -maxdepth 1 -type d -name "$pat" -print0 2>/dev/null)
  done

  # Folder yang mau disisakan hanya versi paling baru
  for pat in "${KEEP_LATEST_DIR_PATTERNS[@]}"; do
    mapfile -d '' -t dirs < <(find "$BOT_DIR" -maxdepth 1 -type d -name "$pat" -printf '%T@ %p\0' 2>/dev/null | sort -zrn)
    local idx=0
    for entry in "${dirs[@]}"; do
      idx=$((idx + 1))
      [ "$idx" -eq 1 ] && continue
      local dpath="${entry#* }"
      rm -rf "$dpath"
      removed=$((removed + 1))
    done
  done

  if [ "$removed" -gt 0 ]; then
    success "Cleanup: $removed item sampah dihapus otomatis"
  else
    log "Tidak ada file sampah ditemukan"
  fi
}

install_dependencies() {
  if command_exists npm; then
    run npm install --prefix "$BOT_DIR"
    return
  fi

  warn "npm belum tersedia, mencoba install Node.js 20."
  if command_exists curl && [ "$(id -u)" -eq 0 ]; then
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
    run apt-get install -y nodejs
    run npm install --prefix "$BOT_DIR"
    return
  fi

  fail "npm tidak ditemukan. Install Node.js/npm lalu jalankan update lagi."
}

restart_pm2() {
  if ! command_exists pm2; then
    warn "PM2 tidak ditemukan, melewati restart otomatis. Jalankan manual: npm install -g pm2 && pm2 start ecosystem.config.js"
    return
  fi

  if [ -f "$BOT_DIR/ecosystem.config.js" ]; then
    (cd "$BOT_DIR" && pm2 startOrReload ecosystem.config.js --only "$APP_NAME") || (cd "$BOT_DIR" && pm2 start ecosystem.config.js)
  else
    (cd "$BOT_DIR" && pm2 restart "$APP_NAME") || (cd "$BOT_DIR" && pm2 start app.js --name "$APP_NAME")
  fi

  pm2 save >/dev/null 2>&1 || true
}

main() {
  log "Update RETRI VPN dimulai"
  log "Target folder: $BOT_DIR"
  log "Backup folder: $BACKUP_DIR"

  command_exists git || fail "git tidak ditemukan. Install git lalu jalankan update lagi."
  command_exists curl || warn "curl tidak ditemukan. Script tetap lanjut jika repo sudah bisa diakses git."

  mkdir -p "$BACKUP_DIR"

  if [ -d "$BOT_DIR" ]; then
    log "Backup konfigurasi dan database"
    for item in "${CONFIG_FILES[@]}"; do
      [ -e "$BOT_DIR/$item" ] && backup_file "$BOT_DIR/$item"
    done
    find "$BOT_DIR" -maxdepth 1 -type f \( -name '*.db' -o -name '*.db-shm' -o -name '*.db-wal' \) -print0 |
      while IFS= read -r -d '' file; do
        backup_file "$file"
      done
  fi

  if [ ! -d "$BOT_DIR/.git" ]; then
    warn "Repo belum ada di $BOT_DIR, clone ulang dari $REPO_URL"
    rm -rf "$BOT_DIR"
    run git clone --branch "$BRANCH" "$REPO_URL" "$BOT_DIR"
  else
    run git -C "$BOT_DIR" fetch origin "$BRANCH"
    run git -C "$BOT_DIR" reset --hard "origin/$BRANCH"
  fi

  restore_backup
  cleanup_junk
  install_dependencies
  restart_pm2

  success "Update selesai. Backup tersimpan di: $BACKUP_DIR"
  echo "Cek status: pm2 status $APP_NAME"
  echo "Cek log:    pm2 logs $APP_NAME"
}

main "$@"
