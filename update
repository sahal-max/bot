#!/bin/bash
# ============================================================
# update — Script auto-update Bot Telegram
# Repo: https://github.com/sahal-max/bot
# ============================================================

set -e

# Warna
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}╔══════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║   🔄 UPDATE BOT TELEGRAM                 ║${NC}"
echo -e "${BLUE}╚══════════════════════════════════════════╝${NC}"
echo ""

# Pastikan di folder BotVPN
if [ ! -d ".git" ]; then
  echo -e "${RED}❌ Error: Bukan folder Git repository!${NC}"
  echo -e "${YELLOW}Pastikan Anda di folder /root/BotVPN${NC}"
  exit 1
fi

# Backup ke /tmp
BACKUP_DIR="/tmp/bot-backup-$(date +%Y%m%d_%H%M%S)"
mkdir -p "$BACKUP_DIR"

echo -e "${YELLOW}📦 Backup konfigurasi & database...${NC}"

# Backup .vars.json
if [ -f ".vars.json" ]; then
  cp .vars.json "$BACKUP_DIR/"
  echo -e "  ✅ .vars.json"
fi

# Backup database
for db in *.db; do
  if [ -f "$db" ]; then
    cp "$db" "$BACKUP_DIR/"
    echo -e "  ✅ $db"
  fi
done

# Backup config JSON lainnya
for cfg in *.json; do
  if [ -f "$cfg" ] && [ "$cfg" != ".vars.json" ]; then
    cp "$cfg" "$BACKUP_DIR/" 2>/dev/null || true
    echo -e "  ✅ $cfg"
  fi
done

echo ""
echo -e "${YELLOW}🔄 Mengambil kode terbaru dari GitHub...${NC}"

# Git operations
git fetch origin
git reset --hard origin/main

echo -e "${GREEN}✅ Kode berhasil diupdate!${NC}"
echo ""

# Restore backup
echo -e "${YELLOW}📂 Restore konfigurasi & database...${NC}"

# Restore .vars.json
if [ -f "$BACKUP_DIR/.vars.json" ]; then
  cp "$BACKUP_DIR/.vars.json" .
  echo -e "  ✅ .vars.json"
fi

# Restore database
for db in "$BACKUP_DIR"/*.db; do
  if [ -f "$db" ]; then
    cp "$db" .
    echo -e "  ✅ $(basename $db)"
  fi
done

# Restore config JSON
for cfg in "$BACKUP_DIR"/*.json; do
  if [ -f "$cfg" ] && [ "$(basename $cfg)" != ".vars.json" ]; then
    cp "$cfg" . 2>/dev/null || true
    echo -e "  ✅ $(basename $cfg)"
  fi
done

echo ""
echo -e "${YELLOW}📦 Update dependencies...${NC}"

# Update npm
if command -v npm &> /dev/null; then
  npm install --silent
  echo -e "${GREEN}✅ Dependencies updated!${NC}"
else
  echo -e "${YELLOW}⚠️  npm tidak ditemukan, skip update dependencies${NC}"
fi

echo ""
echo -e "${YELLOW}🔄 Restart bot...${NC}"

# Restart PM2
if command -v pm2 &> /dev/null; then
  pm2 restart sellvpn --update-env > /dev/null 2>&1
  sleep 5
  
  # Cek status
  if pm2 show sellvpn > /dev/null 2>&1; then
    STATUS=$(pm2 show sellvpn | grep "status" | awk '{print $4}')
    if [ "$STATUS" = "online" ]; then
      echo -e "${GREEN}✅ Bot berhasil di-restart dan online!${NC}"
    else
      echo -e "${RED}⚠️  Bot restart tapi status: $STATUS${NC}"
    fi
  else
    echo -e "${RED}❌ Gagal restart bot via PM2${NC}"
  fi
else
  echo -e "${YELLOW}⚠️  PM2 tidak ditemukan, skip restart${NC}"
fi

# Cleanup
rm -rf "$BACKUP_DIR"

echo ""
echo -e "${GREEN}╔══════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║   ✅ UPDATE SELESAI!                     ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════╝${NC}"
echo ""
echo -e "${BLUE}📋 Cek log: pm2 logs sellvpn --lines 15${NC}"
echo ""
